meta {
  name: PDI Verified Claims
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/demo-api/pdi/claims/{{pdtfUprn}}
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("response has data and jwsSignature", function() {
    expect(res.body).to.have.property("data");
    expect(res.body).to.have.property("jwsSignature");
  });
}
