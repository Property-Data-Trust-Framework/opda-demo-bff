meta {
  name: Get Event (by DID + event name)
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/demo-api/events/{{transactionDid}}/{{event}}
  body: none
  auth: none
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });

  test("event has rawBody", function() {
    expect(res.body).to.have.property("rawBody");
    expect(res.body.rawBody).to.be.a("string").and.not.be.empty;
  });
}
